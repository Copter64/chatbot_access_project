# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here
GAMESERVER_ROLE_NAME=gameserver

# Unifi Configuration
UNIFI_HOST=https://192.168.1.1
UNIFI_USERNAME=your_unifi_username
UNIFI_PASSWORD=your_unifi_password
UNIFI_SITE=default
UNIFI_VERIFY_SSL=true
FIREWALL_GROUP_NAME=GameServerAccess

# Web Server Configuration
WEB_PORT=8443
WEB_HOST=0.0.0.0
WEB_BASE_URL=https://yourdomain.com:8443

# TLS Certificates (Let's Encrypt paths — leave blank for plain HTTP in dev)
SSL_CERT=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Database Configuration
DATABASE_PATH=./data/gameserver_access.db

# IP Access Configuration
IP_EXPIRATION_DAYS=30
TOKEN_EXPIRATION_MINUTES=15
MAX_IPS_PER_USER=5

# Rate Limiting (Discord command — 1 request per N minutes)
RATE_LIMIT_REQUESTS=1
RATE_LIMIT_PERIOD_MINUTES=5

# Cleanup Scheduler
# How often (in hours) to scan for expired IPs and remove them from Unifi
CLEANUP_INTERVAL_HOURS=24
# Override with seconds instead of hours — useful for testing (leave blank in production)
CLEANUP_INTERVAL_SECONDS=
# Days before expiry to send the user a DM warning
EXPIRY_WARNING_DAYS=3

# Web Security
# Max requests per IP per window before returning 429
WEB_RATE_LIMIT_REQUESTS=30
# Rolling window duration in seconds
WEB_RATE_LIMIT_WINDOW_SECONDS=60
# Number of bad token attempts from one IP before sending an admin alert
WEB_BRUTE_FORCE_THRESHOLD=10
# Comma-separated Discord user IDs to DM when brute-force is detected
# Find your ID: Discord > Settings > Advanced > Enable Developer Mode,
# then right-click your name > Copy User ID
ADMIN_DISCORD_USER_IDS=your_discord_user_id_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/bot.log

# Security (for production)
SECRET_KEY=generate_a_random_secret_key_here

# Game Server Connection Info
# Sent to users via DM after their IP is confirmed and access is granted.
# GAMESERVER_HOST is required for the connection block to appear.
# All other fields are optional — leave blank to omit from the DM.
GAMESERVER_NAME=Satisfactory Server
GAMESERVER_HOST=your.server.hostname.or.ip
GAMESERVER_PORT=7777
GAMESERVER_PASSWORD=
GAMESERVER_EXTRA_INFO=
